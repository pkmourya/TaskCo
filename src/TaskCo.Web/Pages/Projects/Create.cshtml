@page
@model TaskCo.Web.Pages.Projects.CreateModel
@{
    ViewData["Title"] = "New Project";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-2">
    <div class="col-md-6">
        <h2 class="mb-4">New Project</h2>

        @if (Model.Error != null)
        {
            <div class="alert alert-danger">@Model.Error</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" maxlength="200" />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3" maxlength="2000"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-page="/Projects/Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
