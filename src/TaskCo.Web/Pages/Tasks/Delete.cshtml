@page
@model TaskCo.Web.Pages.Tasks.DeleteModel
@{
    ViewData["Title"] = "Delete Task";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2 class="mb-4 text-danger">Delete Task</h2>

        @if (Model.Error != null)
        {
            <div class="alert alert-danger">@Model.Error</div>
        }

        <div class="card border-danger mb-4">
            <div class="card-body">
                <h5 class="card-title">@Model.TaskTitle</h5>
                @if (!string.IsNullOrEmpty(Model.TaskDescription))
                {
                    <p class="card-text text-muted">@Model.TaskDescription</p>
                }
            </div>
        </div>

        <p class="text-muted">This task will be permanently deleted.</p>

        <form method="post" class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a asp-page="/Tasks/Index" asp-route-projectId="@Model.ProjectId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
